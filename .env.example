# API base (solo si quieres override en producción; sin trailing slash).
# Por defecto el front usa ruta relativa /api/qnt/v1 y Nginx hace proxy al backend.
#
# Desarrollo: no hace falta. Vite hace proxy de /api/qnt/v1 a http://localhost:8081.
# Producción: no hace falta si Nginx sirve front y API en el mismo dominio; solo define esto
# si la API está en otro host (ej. https://api.otrodominio.com/api/qnt/v1).
#
# Ejemplo para producción en mismo servidor (opcional):
# VITE_API_BASE_URL=/api/qnt/v1

# ── Inspector Térmico ──────────────────────────────────────────────────────
# X-API-Key que el frontend manda a la API del Inspector (contenedor Docker).
# El navegador pega a /api/thermal (proxy Vite en dev → :8000; Nginx en prod).
# Debe coincidir con THERMAL_API_KEY del contenedor. Si no se define, usa la key
# de desarrollo por defecto.
# VITE_THERMAL_API_KEY=dev-local-key-change-me
